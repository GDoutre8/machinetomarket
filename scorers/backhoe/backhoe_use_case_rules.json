{
  "_meta": {
    "file": "backhoe_use_case_rules.json",
    "version": "1.0.0",
    "created": "2026-04-04",
    "purpose": "Use case scoring rules for backhoe loaders. Drives MTM autofill 'What is this machine good for?' and listing language selection.",
    "scoring_notes": "Each use case scores 0–100. Score = spec_score (0–50) + feature_score (0–35) + class_bonus (0–15). Class multipliers applied after base score."
  },

  "scoring_engine": {
    "total_max": 100,
    "components": {
      "spec_score": {
        "max": 50,
        "description": "Score based on how well the machine's OEM specs match the use case requirements"
      },
      "feature_score": {
        "max": 35,
        "description": "Score based on presence of desirable features for this use case"
      },
      "class_bonus": {
        "max": 15,
        "description": "Machine class fit bonus — see backhoe_class_use_case_adjustments.json"
      }
    },
    "thresholds": {
      "excellent": 80,
      "good": 60,
      "capable": 40,
      "marginal": 25,
      "not_recommended": 0
    }
  },

  "use_cases": {

    "trenching": {
      "label": "Trenching",
      "description": "Digging continuous trenches for utilities, drainage, irrigation",
      "typical_customers": ["utility contractors", "plumbers", "irrigation installers", "landscapers"],
      "spec_scoring": {
        "max_dig_depth_ft": {
          "weight": 20,
          "tiers": [
            {"min": 18, "score": 20, "label": "Deep trenching capable"},
            {"min": 15, "score": 15, "label": "Standard depth"},
            {"min": 13, "score": 10, "label": "Adequate"},
            {"min": 0, "score": 5, "label": "Shallow — compact class"}
          ]
        },
        "backhoe_bucket_force_lbf": {
          "weight": 15,
          "tiers": [
            {"min": 14000, "score": 15, "label": "Excellent breakout"},
            {"min": 11000, "score": 11, "label": "Good breakout"},
            {"min": 8000, "score": 7, "label": "Adequate"},
            {"min": 0, "score": 3, "label": "Marginal"}
          ]
        },
        "operating_weight_lbs": {
          "weight": 10,
          "tiers": [
            {"min": 16000, "score": 10, "label": "Full-size — stable"},
            {"min": 10000, "score": 7, "label": "Mid-size"},
            {"min": 5000, "score": 4, "label": "Compact"},
            {"min": 0, "score": 1, "label": "Sub-compact"}
          ]
        },
        "hydraulic_flow_gpm": {
          "weight": 5,
          "tiers": [
            {"min": 35, "score": 5, "label": "High flow — fast cycles"},
            {"min": 25, "score": 3, "label": "Adequate"},
            {"min": 0, "score": 1, "label": "Low flow"}
          ]
        }
      },
      "feature_scoring": {
        "primary": {
          "features": ["extendahoe", "rear_aux_hydraulics", "4wd"],
          "points_each": 7,
          "max": 21
        },
        "secondary": {
          "features": ["pilot_controls", "powershift_transmission", "quick_coupler_rear"],
          "points_each": 4,
          "max": 12
        },
        "bonus": {
          "features": ["enclosed_cab", "hydraulic_thumb"],
          "points_each": 1,
          "max": 2
        }
      }
    },

